# os-vps — environment. Copy to .env.local (gitignored) and fill in.
# os-vps is self-contained: a Next.js app that runs AS a host process and
# controls the machine it runs on. No database, no external backend.

# --- Auth (required) ---
# Single-owner login. The password is a weak/memorable factor; the strong
# factor is device approval (see scripts/approve-device.js). Min 6 chars.
OS_LOGIN_PASSWORD=change-me
# HMAC key that signs the session cookie. MUST be strong — generate with:
#   openssl rand -hex 32
OS_SESSION_SECRET=
# Session lifetime in hours (default 24). Keep it short — a live session can run
# shell commands. Raise only behind a trusted network.
# SESSION_EXPIRY_HOURS=24

# --- Filesystem bounds (optional) ---
# Colon-separated roots. "~" = home, "/" = whole filesystem.
# READ defaults to home + ~/projects; set "/" to browse the whole box read-only.
# OS_FS_READ_ROOTS=/
# WRITE defaults to home + ~/projects (narrow, so the OS can't clobber system files).
# OS_FS_WRITE_ROOTS=~:~/projects

# --- Exec safety + audit (optional) ---
# Catastrophic shell commands (rm -rf /, mkfs, dd to a block device, fork bomb…)
# are refused by default. Set =1 to allow them (do real disk surgery over SSH).
# OS_EXEC_ALLOW_DESTRUCTIVE=1
# Append-only audit trail of exec/file/browser/auth actions. Default path below.
# OS_AUDIT_LOG=~/.os-vps/audit.log

# --- Headless browser service (optional) ---
# The Browser app proxies to a Playwright Chromium service (see os-browser/).
# Leave unset to disable the Browser app (everything else still works).
# OS_BROWSER_URL=http://127.0.0.1:4002
# OS_BROWSER_SECRET=

# --- AI assistant "Alfa" (optional, BYOK) ---
# Bring your own Anthropic key. Can also be set in the OS via Settings → AI
# (stored in ~/.os-vps/config.json). If unset, the assistant returns 501.
# ANTHROPIC_API_KEY=

# --- Storage paths (optional overrides) ---
# OS_DEVICE_STORE=~/.os-vps/auth-devices.json   # approved-device allowlist
# OS_CONFIG_STORE=~/.os-vps/config.json         # BYOK key + model

# --- Public demo build (optional, BUILD-TIME flag) ---
# Build with =1 for a safe public showcase: no login, no host access, no /api
# calls — forced mock data only. Use a separate checkout/service for the demo.
# NEXT_PUBLIC_OS_DEMO=1
