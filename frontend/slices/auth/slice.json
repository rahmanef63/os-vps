{
  "$schema": "https://resource.rahmanef.com/slice-schema.json",
  "slug": "auth",
  "version": "0.1.0",
  "category": "auth",
  "kind": "full",
  "title": "Auth — HMAC signed-cookie gate",
  "description": "Password sign-in/sign-up screen + AuthGate that gates the OS behind a signed HTTP-only cookie. /api/auth/me verifies the HMAC session and rehydrates the user.",
  "namespace": "@/features/auth",
  "frontend": {
    "slicePath": "frontend/slices/auth",
    "configExport": "AuthGate"
  },
  "deps": {
    "npm": ["lucide-react"],
    "shadcn": ["button", "input"],
    "env": [
      { "name": "SUPER_ADMIN_EMAIL", "scope": "server", "required": false, "description": "Super-admin gate for requireAdmin." }
    ],
    "peers": []
  },
  "registers": [],
  "audit": ["bp:public-fn-validator", "bp:rbac-coverage"],
  "license": "MIT",
  "tags": ["auth", "cookie", "login", "session"]
}
